{
  "name": "devgov",
  "version": "0.1.0",
  "description": "Memorable local development governance dashboard and toolkit for ports, startup entries, public routes, worktrees, and self-checks.",
  "type": "module",
  "private": true,
  "scripts": {
    "scan:project": "node scripts/scan-project.mjs",
    "scan:workspace": "node scripts/scan-workspace.mjs",
    "validate:registry": "node scripts/validate-registry.mjs registry",
    "scan:terminal": "node scripts/scan-terminal.mjs",
    "plan:terminal-fix": "node scripts/plan-terminal-fix.mjs",
    "scan:startup": "node scripts/scan-startup.mjs",
    "scan:public-routes": "node scripts/scan-public-routes.mjs",
    "scan:worktrees": "node scripts/scan-worktrees.mjs",
    "scan:docs": "node scripts/scan-docs.mjs",
    "scan:agents": "node scripts/scan-agent-instructions.mjs",
    "scan:api-keys": "node scripts/scan-api-keys.mjs",
    "scan:service-onboarding": "node scripts/scan-service-onboarding.mjs",
    "port:preflight": "node scripts/require-governed-port.mjs",
    "dashboard": "node scripts/serve-dashboard.mjs",
    "dashboard:open": "node scripts/open-dashboard.mjs",
    "dashboard:protocol:register": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/register-dashboard-protocol.ps1",
    "dashboard:protocol:remove": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/register-dashboard-protocol.ps1 -Remove",
    "gov:route:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-gov-public-route.ps1",
    "gov:route:register": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/register-gov-public-route-startup.ps1",
    "gov:route:remove": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/register-gov-public-route-startup.ps1 -Remove",
    "doctor": "node scripts/devgov-doctor.mjs",
    "doctor:repair": "node scripts/devgov-doctor.mjs --repair",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  }
}
