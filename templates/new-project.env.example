# Copy this file to .env.local for local-only development overrides.
# Keep committed .env.example values blank.
# Load dotenv with override:false so existing OS User/Machine environment variables win.

# OpenAI-compatible clients.
OPENAI_API_KEY=

# Anthropic clients.
ANTHROPIC_API_KEY=

# Cloudflare CLI, SDK, or tunnel automation.
CF_API_TOKEN=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_EMAIL=

# Google AI Studio or Gemini clients.
Gemini_API_KEY=

# Hugging Face Hub, inference, or dataset tooling.
HF_API_Token=

# NVIDIA API Catalog, NIM, or NGC clients.
nvapi=
